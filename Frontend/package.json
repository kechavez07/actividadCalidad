{
  "name": "ticketpremium-fifa2026",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "desktop:dev": "pnpm --filter web dev & pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter web build && pnpm --filter desktop build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
