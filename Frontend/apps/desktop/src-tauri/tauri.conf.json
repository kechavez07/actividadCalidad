{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TicketPremium FIFA 2026",
  "version": "1.0.0",
  "identifier": "com.ticketpremium.fifa2026",
  "build": {
    "beforeDevCommand": "cd ../../ && pnpm --filter web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../../ && pnpm --filter web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "TicketPremium FIFA 2026",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
